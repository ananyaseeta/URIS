# Test environment overrides
# Raise rate limits so Playwright's 25 tests don't hit the login ceiling
RATE_LIMIT_LOGIN_MAX=500
RATE_LIMIT_REGISTER_MAX=100

# Test database — uses the same Postgres instance as dev but is safe because
# integration tests create uniquely-named records and delete them in afterEach.
DATABASE_URL="postgresql://postgres:1212@127.0.0.1:5433/uris_db"
NODE_ENV=test
